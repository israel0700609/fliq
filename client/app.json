{
  "expo": {
    "name": "fliq",
    "slug": "fliq",
    "version": "1.0.0",
    "orientation": "automatic",
    "icon": "./assets/images/icon.png",
    "scheme": "fliq",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.fliq",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app needs access to the microphone to let you describe your movie vibe.",
        "NSSpeechRecognitionUsageDescription": "This app uses speech recognition to convert your voice into search terms."
      }
    },
    "android": {
      "package": "com.yourname.fliq",
      "permissions": [
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "@react-native-voice/voice",
        {
          "microphonePermission": "Allow fliq to access the microphone",
          "speechRecognitionPermission": "Allow fliq to use speech recognition"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
